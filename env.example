# Ask Trusscore Bot — Environment Variables
# Copy this to .env and fill in your values. Never commit .env to source control.

# ── Azure Bot Registration ────────────────────────────────────────────────────
# From Azure Portal → Bot Services → your bot → Configuration
MICROSOFT_APP_ID=your-azure-app-id-here
MICROSOFT_APP_PASSWORD=your-azure-app-secret-here

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── NetSuite ──────────────────────────────────────────────────────────────────
# Your NetSuite Account ID (e.g. 1234567 or 1234567_SB1 for sandbox)
# Found at Setup → Company → Company Information → Account ID
NETSUITE_ACCOUNT_ID=your-netsuite-account-id

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3978
